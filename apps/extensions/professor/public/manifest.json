{
  "manifest_version": 3,
  "name": "Inicie Professor",
  "version": "0.1.0",
  "description": "Painel do professor para chat e screenshot em tempo real.",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["http://localhost:3000/*", "http://localhost:1883/*", "ws://localhost:8083/*"],
  "action": {
    "default_title": "Inicie Professor",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png"
    }
  }
}
